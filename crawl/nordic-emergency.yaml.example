# Example: Crawl one site into generated/nordic-emergency.zim and register it locally
#
# Usage:
#   svalbard crawl config crawl/nordic-emergency.yaml.example
#   # or copy to .yaml first and edit as needed

name: Nordic Emergency Services
description: Finnish rescue service guidance
tags: [first-aid, fire-shelter, navigation]
depth: comprehensive

sites:
  - url: https://www.pelastustoimi.fi
    scope: domain
    page_limit: 500

# Default limits applied per-site (override per-site if needed)
defaults:
  size_limit_mb: 512
  timeout_minutes: 60
